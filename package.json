{
  "name": "opengravity",
  "version": "1.0.0",
  "description": "Personal AI Telegram Agent on Firebase",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/index.local.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "elevenlabs": "^1.0.3",
    "express": "^5.2.1",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "grammy": "^1.31.0",
    "groq-sdk": "^0.8.0",
    "text2wav": "^0.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.17.0",
    "firebase-tools": "^13.23.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
