# ===================
# Required Variables
# ===================

TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_ALLOWED_USER_IDS="YOUR_TELEGRAM_USER_ID"
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# ===================
# Optional Variables
# ===================

# LLM Fallbacks
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-flash-1.5-8b"
GEMINI_API_KEY=""

# Database
DB_PATH="./memory.db"

# Firebase
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"

# ===================
# Voice Configuration
# ===================

# Local Mode (for home use with Qwen3-TTS)
# Set to true only when running locally with GPU
IS_LOCAL=false
LOCAL_TTS_URL="http://localhost:5001"

# Voice Prompt (optional, has default)
# VOICE_PROMPT="your custom voice description..."

# Production voice timeout (optional, in milliseconds)
# TTS_TIMEOUT=10000
